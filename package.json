{
  "name": "another-react-tailwind-component-library",
  "private": true,
  "version": "0.1.0",
  "description": "A React + Tailwind CSS v4 component library built on Radix primitives, styled with container queries.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NoActionJaxn/another-react-tailwind-component-library.git"
  },
  "keywords": [
    "react",
    "tailwindcss",
    "component-library",
    "radix-ui",
    "ui"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/theme.css": "./dist/styles/theme.css",
    "./styles/components.css": "./dist/styles/components.css",
    "./styles/components/*.css": "./dist/styles/components/*.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build --config vite.lib.config.ts && node scripts/copy-styles.mjs",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "radix-ui": "^1.6.2",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-paginate": "^8.3.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react-paginate": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.7.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.0.0",
    "playwright": "^1.61.1",
    "prettier": "^3.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-paginate": "^8.3.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
